class Result {
    // Print the resultant matrix after (A * B)
    static void multiplyMatrix(int A[][],int B[][], int R1, int C1, int R2, int C2) {
      int C[][]=new int[R1][C2];
      for(int i=0;i<R1;i++){
        for(int j=0;j<C2;j++){
          int s=0;
          for(int k=0;k<C1;k++){
