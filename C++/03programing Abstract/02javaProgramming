class Result {
    static void printSpiral(int a[][], int r, int c) {
      int rs=0;
      int re=r-1;
      int cs=0;
      int ce=c-1;
      int ele=r*c;
      int count=0;
      while(count<ele){
        for(int i=cs;count<ele && i<=ce;i++){
          System.out.println(a[rs][i]);
          count++;
        }
        rs++;
        for(int i=rs;count<ele && i<=re;i++){
