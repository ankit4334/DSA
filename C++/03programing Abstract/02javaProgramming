static boolean palindrom(String str) {
    int s=0;
    int e=str.length()-1;
    while(s<=e){
      if(str.charAt(s)!=str.charAt(e)){
        return false;
      }
      else{
        s++;
        e--;
      }
    }
    return true;
  }
  static boolean pal(String str) {
    char a[]=str.toCharArray();
     int s=0;
     int e=a.length-1;
     for(int i=0;i<a.length;i++){
       if(a[i]!=a[e]){
         return false;
       }
       else{
         s++;
         e--;
       }
     }
    return true;
  }
  static int countPalindrome(String str) {
    str=str.toUpperCase();
    String s[]=str.split(" ");
    int c=0;
    for(String w:s){
      if(palindrom(w)){
        c++;
      }
    }
     return c;
