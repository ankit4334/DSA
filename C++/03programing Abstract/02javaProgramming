// Return the reversed string
static String reverseString(String str) {
    char a[]=str.toCharArray();
    int s=0;
    int e=a.length-1;
    while(s<=e){
      char t=a[s];
      a[s]=a[e];
      a[e]=t;
      s++;
      e--;
    }
    return String.valueOf(a);
  }

