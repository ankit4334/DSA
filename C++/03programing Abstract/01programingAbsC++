    MemoryCalculator(int seed) : Calculator(seed), computeCount(0), memoCount(0) {}
    int kthPrime(int k) override {
        auto it = memo.find(k);
        if (it != memo.end()) {
            memoCount++;
            return it->second;
        } else {
            computeCount++;
            int result = Calculator::kthPrime(k);
            memo[k] = result;
            return result;
        }
    }
