#include<stack>
void flipHalfQueue(queue<int>& q) {
    int n = q.size();
    stack<int> s;
    for(int i = 0; i < n; i++) {
        int x = q.front();
        q.pop();
        if(i % 2 == 1) {
            s.push(x);
        }
        q.push(x);
    }
    for(int i = 0; i < n; i++) {
        int x = q.front();
        q.pop();
        if(i % 2 == 1) {
            q.push(s.top());
            s.pop();
        }
        else {
            q.push(x);
        }
    }
}

