#include<bits/stdc++.h>
int c=0;
void allPermutations(string str, vector<string> &permutations){
  // Write your code here
  if(c==0){
    sort(str.begin(),str.end());
    c++;
  }
  int n=str.length();
  if(n==1){
    permutations.push_back(str);
    return ;
  }
  int i=0;
  for(i=n-1;i>0;i--){
    if(str[i-1]<str[i]){
      break;
    }
  }
