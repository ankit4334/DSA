and returns a set containing all the numbers in the vector that appear exactly thrice.

For example, if a vector variable v stores {1, 1, 1, 4, 13, 17, -12, 33, 17, 82, 17, 61}, the call of thrice(v) should return the set {1, 17}.

// Complete the below function as specified below.
#include<map>
set<int> thrice(vector<int>& v)
{
	map<int ,int> m;
  set<int>s;
  for(auto it : v){
    m[it]++;
  }
  for(auto it:m){
    if(it.second==3){
      s.insert(it.first);
    }
  }
  return s;
}



